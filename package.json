{
  "name": "vortex-game",
  "version": "1.0.0",
  "description": "VORTEX - Real-time multiplayer cosmic arena game",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "build:android": "npx cap sync android && npx cap open android",
    "build:ios": "npx cap sync ios && npx cap open ios",
    "build:web": "echo 'Deploy public/ folder to your hosting provider'",
    "setup": "node scripts/setup.js",
    "db:seed": "node scripts/seed.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.4.1",
    "uuid": "^9.0.0",
    "stripe": "^14.14.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0",
    "@capacitor/core": "^5.7.0",
    "@capacitor/android": "^5.7.0",
    "@capacitor/ios": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
